# Alarmist — Environment Variables
# Copy to .env for local dev. Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-64-char-random-hex-string

# PostgreSQL — local example (Render sets this automatically in production)
DATABASE_URL=postgresql://postgres:password@localhost:5432/alarmist

# ── Twilio (SMS OTP) ──────────────────────────────────────────────────────────
# Leave blank to run in Demo Mode (OTP printed to console, no SMS sent)
# Get from: https://console.twilio.com → Account Info

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Optional ──────────────────────────────────────────────────────────────────
FLASK_ENV=development
PORT=5000
WEB_CONCURRENCY=3
